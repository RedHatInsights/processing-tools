name: BDD Tests

on:
  push:
    branches: [main, master]
  pull_request:

jobs:
  bdd:
    name: BDD tests
    uses: RedHatInsights/processing-tools/.github/workflows/bdd.yaml@v0.4.4
    with:
      service: {{ service }}
      {% if extra_options is defined %}
        {% for key, value in extra_options %}
      {{ key }}: {{ value }}
        {% endfor %}
      {% endif %}
